{
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.ipynb": "jupyter-notebook",
        "*.parquet": "duckdb.dataFileViewer",
        "*.csv": "duckdb.dataFileViewer",
        "*.tsv": "duckdb.dataFileViewer",
        "*.jsonl": "duckdb.dataFileViewer",
        "*.ndjson": "duckdb.dataFileViewer"
    },
    "duckdb.databases": [
        {
            "alias": "taxi_pipeline",
            "type": "file",
            "path": "/workspaces/OpenLibrary/taxi_pipeline.duckdb",
            "readOnly": true,
            "attached": true
        }
    ],
    "duckdb.defaultDatabase": "taxi_pipeline"
}